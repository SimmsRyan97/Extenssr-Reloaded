{
  "name": "extenssr",
  "version": "3.11.19",
  "description": "'Extenssr Reloaded - A browser extension for GeoGuessr. Original extension by Andrei Onea.'",
  "scripts": {
    "chrome": "npx webpack --mode=production -c webpack.chrome.ts",
    "watch-chrome": "npx webpack -w --mode=development --progress -c webpack.chrome.ts",
    "chrome-nokey": "npx webpack --mode=production -c webpack.chrome-nokey.ts",
    "chrome-nokey-debug": "npx webpack --mode=production -c webpack.chrome-nokey-debug.ts",
    "watch-chrome-nokey": "npx webpack -w --mode=development --progress -c webpack.chrome-nokey.ts",
    "safari": "npx webpack --mode=production -c webpack.safari.ts",
    "postsafari": "mkdir extenssr_xcode && xcrun safari-web-extension-converter --no-prompt --bundle-identifier com.andreionea.extenssr --swift --app-name Extenssr Reloaded extenssr_safari",
    "firefox": "npx webpack --mode=production -c webpack.firefox.ts",
    "watch-firefox": "npx webpack -w --mode=production --progress -c webpack.firefox.ts",
    "firefox-debug": "npx webpack --mode=production -c webpack.firefox-debug.ts",
    "watch-safari": "npx webpack -w --mode=development --progress -c webpack.safari.ts",
    "clean": "rm -rf extenssr_* Extenssr",
    "gendocs": "typedoc src/content_main.ts --out docs",
    "test": "npx jest",
    "coverage": "npx jest --collectCoverage",
    "watch-test": "npx jest --watch",
    "lint": "eslint .",
    "ci-lint": "eslint --format gitlab .",
    "lint-fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "Andrei Onea",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/preset-typescript": "^7.18.6",
    "@types/chrome": "^0.0.161",
    "@types/copy-webpack-plugin": "^8.0.1",
    "@types/jest": "^28.1.4",
    "@types/node": "^14.14.22",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/webextension-polyfill": "^0.8.1",
    "@types/webpack": "^5.28.0",
    "@types/ws": "^8.2.0",
    "@typescript-eslint/eslint-plugin": "^5.30.4",
    "@typescript-eslint/parser": "^5.30.4",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^10.0.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-formatter-gitlab": "^3.0.0",
    "eslint-plugin-react": "^7.30.1",
    "jest": "^28.1.2",
    "jest-extended": "^2.0.0",
    "jest-text-transformer": "^1.0.4",
    "ts-jest": "^28.0.5",
    "ts-loader": "^9.2.5",
    "ts-node": "^10.2.1",
    "tsconfig-paths-webpack-plugin": "^4.0.0",
    "type-fest": "^2.1.0",
    "typedoc": "^0.22.7",
    "typescript": "^4.4.2",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "webpack-glsl-loader": "^1.0.1",
    "zip-webpack-plugin": "^4.0.1"
  },
  "dependencies": {
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@mui/icons-material": "^5.8.4",
    "@mui/material": "^5.8.7",
    "@mui/styled-engine": "^5.8.7",
    "@mui/styled-engine-sc": "^5.8.0",
    "@shaderfrog/glsl-parser": "^0.2.2",
    "@types/google.maps": "^3.46.0",
    "@types/jsonwebtoken": "^8.5.5",
    "@types/mousetrap": "^1.6.8",
    "@types/offscreencanvas": "^2019.7.0",
    "@types/rbush": "^3.0.0",
    "@types/zip-webpack-plugin": "^3.0.3",
    "axios": "^1.13.6",
    "base64-arraybuffer": "^1.0.1",
    "cross-blob": "^3.0.0",
    "cross-env": "^7.0.3",
    "dexie": "^3.0.3",
    "form-data": "^4.0.0",
    "format-duration": "^1.4.0",
    "i18n-iso-countries": "^7.4.0",
    "inversify": "^6.0.1",
    "inversify-inject-decorators": "^3.1.0",
    "jsonwebtoken": "^9.0.0",
    "jszip": "^3.9.1",
    "lint": "^1.1.2",
    "mousetrap": "^1.6.5",
    "onnxruntime-web": "^1.12.0",
    "point-in-polygon": "^1.1.0",
    "rbush": "^3.0.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "reflect-metadata": "git+https://github.com/conoremclaughlin/reflect-metadata.git/#9a5223f018c7dde66278f0a30a9fb4901e7aa7d4",
    "string-hash": "^1.1.3",
    "webextension-polyfill": "^0.8.0",
    "when-dom-ready": "^1.2.12",
    "ws": "^8.2.2",
    "xterm": "^4.18.0",
    "xterm-addon-fit": "^0.5.0"
  }
}
